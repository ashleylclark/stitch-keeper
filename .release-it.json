{
  "$schema": "https://unpkg.com/release-it@19/schema/release-it.json",
  "git": {
    "requireBranch": "main",
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": true
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "infile": "CHANGELOG.md",
      "preset": {
        "name": "conventionalcommits"
      }
    }
  },
  "hooks": {
    "before:init": [
      "npm run lint",
      "npm run build"
    ],
    "after:bump": "node ./scripts/sync-chart-version.mjs ${version}",
    "after:release": "echo Released v${version}. Container publishing will run from the pushed tag."
  }
}
